{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "declaration": false,
        "rootDir": "src",
        "sourceMap": false,
        "jsx": "react"
    },
    "exclude": [
        "src/index.tsx"
    ],
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx"
    ]
}